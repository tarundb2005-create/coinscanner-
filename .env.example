# =====================================================
# CoinScanner - Environment Variables
# =====================================================
# Copy this file to .env and replace every placeholder.
# Do not commit real secrets.
# =====================================================

# Flask session signing key.
# Generate a strong value locally:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret-key

# Railway PostgreSQL connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Railway Redis connection string.
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# MSG91 SMS OTP API key.
MSG91_API_KEY=replace-with-msg91-api-key

# CoinDCX authenticated API credentials.
COINDCX_API_KEY=replace-with-coindcx-api-key
COINDCX_SECRET=replace-with-coindcx-secret

# newsdata.io API key for the News page.
NEWS_API_KEY=replace-with-newsdata-api-key

# Public frontend origin used by production integrations.
FRONTEND_URL=https://your-production-domain.example

# Flask runtime environment.
FLASK_ENV=production
