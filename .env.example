# =====================================================
# CoinScanner — Environment Variables
# =====================================================
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in YOUR values below (replace the placeholders)
#   3. NEVER commit .env to Git — it is already in .gitignore
#
# This .env.example file is safe to commit — it has no real secrets.
# =====================================================


# ── REQUIRED ─────────────────────────────────────────

# Flask session signing key — must be a long random string.
# Generate one instantly:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here


# ── RECOMMENDED ──────────────────────────────────────

# newsdata.io API key — the News page shows nothing without this.
# Free tier: 200 requests/day, 10 results per request.
# Sign up free at: https://newsdata.io/register
# After signup your key looks like: pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEWS_API_KEY=your-newsdata-io-api-key-here


# ── NOT NEEDED (free APIs, no key required) ──────────
# CoinDCX    → free public API, no key needed
# CoinGecko  → free public API, no key needed (250 coins fetched)
# Clearbit   → free logo API, no key needed

# Resend API key — OTP email delivery for signup + password reset
# Free tier: 3,000 emails/month, 100/day
# Sign up at: https://resend.com (no credit card required)
# Your key looks like: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# If not set, OTPs are console-logged only (development fallback)
RESEND_API_KEY=your-resend-api-key-here

# Sender address used for OTP emails.
# For initial Render testing, the default onboarding@resend.dev is fine.
EMAIL_FROM_ADDRESS=onboarding@resend.dev

# AWS RDS / Aurora PostgreSQL connection string.
# Leave blank for local SQLite development.
DATABASE_URL=

# Flask environment — controls secure cookie flag
# Set to 'production' on Render / Railway / Heroku
# Leave as 'development' for local testing
FLASK_ENV=development

# Enable secure cookies when serving behind HTTPS on AWS.
SESSION_COOKIE_SECURE=false

# MSG91 SMS OTP delivery configuration.
# Sign up at: https://msg91.com and create an API key.
MSG91_API_KEY=your-msg91-api-key-here
# Optional sender ID. Use the sender ID approved in your MSG91 account.
MSG91_SENDER_ID=MSGIND

# MSG91 API key — OTP SMS delivery using MSG91
# Sign up at: https://msg91.com and create an API key.
MSG91_API_KEY=your-msg91-api-key-here
# Optional sender ID. Use the sender ID approved in your MSG91 account.
MSG91_SENDER_ID=MSGIND

# MSG91 web widget settings — only needed if you want the client-side
# sendOtp widget to render on the verify page.
MSG91_WIDGET_ID=your-msg91-widget-id
MSG91_TOKEN_AUTH=your-msg91-token-auth

# Upstash / Redis connection URL (optional). If set, app will use Redis for caching and OTP storage.
REDIS_URL=

# Comma-separated list of allowed CORS origins (production domain(s)).
# Example: https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
